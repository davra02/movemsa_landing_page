---

<section class="contact" id="contacto">
  <div class="contact__inner container">
    <header class="contact__header">
      <span class="section-label">Contacto</span>
      <h2 class="section-title">¿Hablamos?</h2>
      <p class="contact__intro">
        Si tienes preguntas sobre alguna actividad, quieres reservar una clase o simplemente quieres saber más sobre MovEmSa, escríbenos. Respondemos siempre.
      </p>
    </header>

    <div class="contact__body">
      <!-- Contact info -->
      <div class="contact__info">
        {contactInfo.map(({ icon, label, value, href }) => (
          <a class="contact-item" href={href} target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}>
            <span class="contact-item__icon" set:html={icon} />
            <span class="contact-item__text">
              <span class="contact-item__label">{label}</span>
              <span class="contact-item__value">{value}</span>
            </span>
          </a>
        ))}
      </div>

      <!-- Form -->
      <form class="contact-form" id="contact-form" action="https://formspree.io/f/xqevjzjz" method="POST" novalidate>
        <input type="hidden" name="_subject" value="Nuevo mensaje desde MovEmSa" />
        <div class="form-group">
          <label for="nombre">Nombre</label>
          <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required />
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="tu@email.com" required />
        </div>
        <div class="form-group">
          <label for="mensaje">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="5" placeholder="Cuéntanos qué necesitas..." required></textarea>
        </div>
        <button type="submit" class="btn-primary contact-form__submit" id="form-submit">Enviar mensaje</button>
        <p class="form-success" id="form-success" aria-live="polite">
          ✓ Mensaje enviado. ¡Nos ponemos en contacto contigo pronto!
        </p>
        <p class="form-error" id="form-error" aria-live="polite">
          Algo ha fallado. Inténtalo de nuevo o escríbenos directamente al email.
        </p>
      </form>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--clr-bg-alt);
    padding-block: 6rem;
  }

  .contact__header {
    text-align: center;
    max-width: 560px;
    margin-inline: auto;
    margin-block-end: 4rem;
  }

  .contact__header .section-label {
    display: block;
    margin-block-end: 0.75rem;
  }

  .contact__intro {
    margin-block-start: 1rem;
    color: var(--clr-text-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .contact__body {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    align-items: start;
  }

  /* Contact info items */
  .contact__info {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    text-decoration: none;
    color: var(--clr-text);
    background: var(--clr-white);
    border-radius: var(--radius);
    padding: 1.25rem;
    border: 1px solid rgba(75,191,181,0.15);
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .contact-item:hover {
    box-shadow: 0 4px 20px rgba(75,191,181,0.12);
    transform: translateX(4px);
  }

  .contact-item__icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    color: var(--clr-primary-dark);
    margin-block-start: 0.15rem;
  }

  .contact-item__icon svg {
    width: 100%;
    height: 100%;
  }

  .contact-item__text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .contact-item__label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--clr-text-muted);
  }

  .contact-item__value {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--clr-text);
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background: var(--clr-white);
    border-radius: var(--radius);
    padding: 2rem;
    border: 1px solid rgba(75,191,181,0.15);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--clr-text);
    letter-spacing: 0.02em;
  }

  .form-group input,
  .form-group textarea {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--clr-text);
    background: var(--clr-bg);
    border: 1.5px solid rgba(75,191,181,0.25);
    border-radius: 8px;
    padding: 0.7rem 1rem;
    resize: vertical;
    transition: border-color var(--transition), box-shadow var(--transition);
    outline: none;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--clr-text-muted);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--clr-primary);
    box-shadow: 0 0 0 3px rgba(75,191,181,0.15);
  }

  .contact-form__submit {
    align-self: flex-start;
    margin-block-start: 0.5rem;
  }

  .contact-form__submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .form-success,
  .form-error {
    display: none;
    font-size: 0.95rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    margin-block-start: 0.25rem;
  }

  .form-success {
    background: rgba(75,191,181,0.12);
    color: var(--clr-primary-dark);
    border: 1px solid rgba(75,191,181,0.3);
  }

  .form-error {
    background: rgba(220,80,80,0.08);
    color: #c0392b;
    border: 1px solid rgba(220,80,80,0.2);
  }

  .form-success.visible,
  .form-error.visible {
    display: block;
  }

  @media (max-width: 768px) {
    .contact__body {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('form-submit') as HTMLButtonElement;
  const success = document.getElementById('form-success')!;
  const error = document.getElementById('form-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Enviando...';
    success.classList.remove('visible');
    error.classList.remove('visible');

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        success.classList.add('visible');
        form.reset();
      } else {
        error.classList.add('visible');
      }
    } catch {
      error.classList.add('visible');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enviar mensaje';
    }
  });
</script>
