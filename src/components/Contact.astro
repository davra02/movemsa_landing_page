---
const contactInfo = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>`,
    label: 'Email',
    value: 'info@movemsa.com',
    href: 'mailto:info@movemsa.com',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>`,
    label: 'Teléfono',
    value: '+34 614 056 383',
    href: 'tel:+34614056383',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.8" fill="none"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" stroke="currentColor" stroke-width="1.8" fill="none"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
    label: 'Instagram',
    value: '@movimiento_emocion_salud',
    href: 'https://instagram.com/movimiento_emocion_salud',
  },
];
---

<section class="contact" id="contacto">
  <div class="contact__inner container">
    <header class="contact__header">
      <span class="section-label">Contacto</span>
      <h2 class="section-title">¿Hablamos?</h2>
      <p class="contact__intro">
        Si tienes preguntas sobre alguna actividad, quieres reservar una clase o simplemente quieres saber más sobre MovEmSa, escríbenos. Respondemos siempre.
      </p>
    </header>

    <div class="contact__body">
      <!-- Contact info -->
      <div class="contact__info">
        {contactInfo.map(({ icon, label, value, href }) => (
          <a class="contact-item" href={href} target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}>
            <span class="contact-item__icon" set:html={icon} />
            <span class="contact-item__text">
              <span class="contact-item__label">{label}</span>
              <span class="contact-item__value">{value}</span>
            </span>
          </a>
        ))}
      </div>

      <!-- Form -->
      <form class="contact-form" action="#" method="post" novalidate>
        <div class="form-group">
          <label for="nombre">Nombre</label>
          <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required />
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="tu@email.com" required />
        </div>
        <div class="form-group">
          <label for="mensaje">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="5" placeholder="Cuéntanos qué necesitas..." required></textarea>
        </div>
        <button type="submit" class="btn-primary contact-form__submit">Enviar mensaje</button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--clr-bg-alt);
    padding-block: 6rem;
  }

  .contact__header {
    text-align: center;
    max-width: 560px;
    margin-inline: auto;
    margin-block-end: 4rem;
  }

  .contact__header .section-label {
    display: block;
    margin-block-end: 0.75rem;
  }

  .contact__intro {
    margin-block-start: 1rem;
    color: var(--clr-text-muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .contact__body {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    align-items: start;
  }

  /* Contact info items */
  .contact__info {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    text-decoration: none;
    color: var(--clr-text);
    background: var(--clr-white);
    border-radius: var(--radius);
    padding: 1.25rem;
    border: 1px solid rgba(75,191,181,0.15);
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .contact-item:hover {
    box-shadow: 0 4px 20px rgba(75,191,181,0.12);
    transform: translateX(4px);
  }

  .contact-item__icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    color: var(--clr-primary-dark);
    margin-block-start: 0.15rem;
  }

  .contact-item__icon svg {
    width: 100%;
    height: 100%;
  }

  .contact-item__text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .contact-item__label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--clr-text-muted);
  }

  .contact-item__value {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--clr-text);
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background: var(--clr-white);
    border-radius: var(--radius);
    padding: 2rem;
    border: 1px solid rgba(75,191,181,0.15);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--clr-text);
    letter-spacing: 0.02em;
  }

  .form-group input,
  .form-group textarea {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--clr-text);
    background: var(--clr-bg);
    border: 1.5px solid rgba(75,191,181,0.25);
    border-radius: 8px;
    padding: 0.7rem 1rem;
    resize: vertical;
    transition: border-color var(--transition), box-shadow var(--transition);
    outline: none;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--clr-text-muted);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--clr-primary);
    box-shadow: 0 0 0 3px rgba(75,191,181,0.15);
  }

  .contact-form__submit {
    align-self: flex-start;
    margin-block-start: 0.5rem;
  }

  @media (max-width: 768px) {
    .contact__body {
      grid-template-columns: 1fr;
    }
  }
</style>
