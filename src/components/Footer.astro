---
import logoSrc from '../assets/header_logo.png';
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__brand">
      <a href="#inicio" class="footer__logo" aria-label="MovEmSa inicio">
        <img src={logoSrc.src} alt="MovEmSa" width="52" height="52" />
      </a>
      <p class="footer__tagline">
        Movimiento, Emoción, Salud.<br />
        <em>Porque moverse bien es sentirse bien.</em>
      </p>
    </div>

    <nav class="footer__nav" aria-label="Navegación pie de página">
      <a href="#por-que">Por qué</a>
      <a href="#actividades">Actividades</a>
      <a href="#nosotras">Nosotras</a>
      <a href="#ubicacion">Ubicación</a>
      <a href="#contacto">Contacto</a>
    </nav>

    <div class="footer__social">
      <a
        href="https://instagram.com/movimiento_emocion_salud"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram de MovEmSa"
        class="footer__social-link"
      >
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.8" fill="none"/>
          <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" stroke="currentColor" stroke-width="1.8" fill="none"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </a>
      <a
        href="https://www.tiktok.com/@movemsa"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="TikTok de MovEmSa"
        class="footer__social-link"
      >
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V9.14a8.16 8.16 0 004.77 1.52V7.21a4.85 4.85 0 01-1-.52z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
      </a>
    </div>
  </div>

  <div class="footer__bottom container">
    <p>&copy; {new Date().getFullYear()} MovEmSa · Movimiento, Emoción, Salud. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--clr-surface-dark);
    padding-block: 4rem 1.5rem;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr auto;
    gap: 3rem;
    align-items: start;
    padding-block-end: 3rem;
    border-block-end: 1px solid rgba(255,255,255,0.08);
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer__logo img {
    width: 52px;
    height: 52px;
    object-fit: contain;
    filter: invert(1) brightness(1.1);
  }

  .footer__tagline {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
  }

  .footer__tagline em {
    font-style: italic;
    color: var(--clr-primary);
  }

  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__nav a {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer__nav a:hover {
    color: var(--clr-primary);
  }

  .footer__social {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .footer__social-link {
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    color: rgba(255,255,255,0.6);
    transition: border-color var(--transition), color var(--transition);
  }

  .footer__social-link:hover {
    border-color: var(--clr-primary);
    color: var(--clr-primary);
  }

  .footer__social-link svg {
    width: 18px;
    height: 18px;
  }

  .footer__bottom {
    margin-block-start: 1.5rem;
    text-align: center;
  }

  .footer__bottom p {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.3);
  }

  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer__nav {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem 1.5rem;
    }
  }
</style>
